# Zerodha Credentials
ZERODHA_USER_ID=your_user_id_here        # e.g. AB1234
ZERODHA_PASSWORD=your_password_here
ZERODHA_TOTP_SECRET=your_totp_secret_here  # The 32-char base32 secret from Zerodha 2FA setup

# Telegram (optional — for trade alerts)
TELEGRAM_BOT_TOKEN=your_bot_token_here   # From @BotFather
TELEGRAM_CHAT_ID=your_chat_id_here       # Your Telegram user/chat ID
